---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base title="Insights | Kuma Huang" description="MZ 世代品牌洞察、世代溝通策略、品牌語言翻譯 — Kuma Huang 來自夾層世代的觀點">

  <section class="page-hero">
    <div class="page-hero-inner">
      <p class="page-label">INSIGHTS</p>
      <h1 class="page-title">Brand Insights</h1>
      <p class="page-sub">來自夾層世代的品牌觀察</p>
    </div>
  </section>

  <section class="blog-section">
    <div class="blog-inner">
      <div class="posts-list">
        {posts.map((post, i) => (
          <a href={`/blog/${post.id}`} class="post-item">
            <div class="post-meta">
              <time>{post.data.date.toISOString().slice(0,10)}</time>
              <span class="post-tag">{post.data.category}</span>
            </div>
            <div class="post-content">
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
            </div>
            <span class="post-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

</Base>

<style>
  .page-hero {
    padding: calc(var(--nav-h) + 6rem) 2rem 4rem;
    border-bottom: 1px solid var(--gray-800);
  }
  .page-hero-inner { max-width: var(--max-w); margin: 0 auto; }
  .page-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    background: var(--grad-fire);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 2rem;
  }
  .page-title {
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    margin-bottom: 1rem;
    background: var(--grad-cool);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .page-sub { font-size: 1.1rem; color: var(--gray-400); }

  .blog-section { padding: 0 2rem; }
  .blog-inner { max-width: var(--max-w); margin: 0 auto; }

  .post-item {
    display: grid;
    grid-template-columns: 180px 1fr auto;
    gap: 2rem;
    padding: 3rem 0;
    border-bottom: 1px solid var(--gray-800);
    align-items: center;
    transition: background 0.2s;
  }
  .post-item:hover { background: var(--dark); padding-left: 2rem; padding-right: 2rem; margin: 0 -2rem; }

  .post-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .post-meta time {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--gray-600);
  }
  .post-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    background: var(--grad-main);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-transform: uppercase;
  }

  .post-content h2 {
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }
  .post-content p {
    color: var(--gray-500);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .post-arrow {
    font-size: 1.5rem;
    color: var(--gray-700);
    transition: all 0.3s;
  }
  .post-item:hover .post-arrow {
    color: var(--neon-purple);
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .post-item {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
    .post-meta { flex-direction: row; gap: 1rem; }
    .post-arrow { display: none; }
  }
</style>
