---
import Base from '../layouts/Base.astro';
---

<Base title="Contact | Kuma Huang" description="預約 Kuma Huang 免費 30 分鐘品牌世代診斷，讓你的品牌被 MZ 世代看見">

  <section class="page-hero">
    <div class="page-hero-inner">
      <p class="page-label">CONTACT</p>
      <h1 class="page-title">Let's Decode</h1>
      <p class="page-sub">預約免費品牌世代診斷</p>
    </div>
  </section>

  <section class="contact-section">
    <div class="contact-inner">
      <div class="contact-info">
        <div class="info-block">
          <h3>FREE CONSULTATION</h3>
          <p>30 分鐘免費線上診斷。我會直接告訴你，你的品牌在 MZ 世代眼中長什麼樣子，以及最該優先處理的 3 件事。</p>
          <p>不推銷、不廢話。如果我幫不了你，我會直接說。</p>
        </div>

        <div class="info-block">
          <h4>EMAIL</h4>
          <a href="mailto:bear@howdy.tw" class="info-link">bear@howdy.tw</a>
        </div>

        <div class="info-block">
          <h4>RESPONSE TIME</h4>
          <p class="info-detail">24 小時內回覆</p>
        </div>

        <div class="info-block">
          <h4>BASED IN</h4>
          <p class="info-detail">Taiwan / Remote Worldwide</p>
        </div>
      </div>

      <div class="contact-form-wrap">
        <form class="contact-form" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
          <div class="form-group">
            <label for="name">NAME</label>
            <input type="text" id="name" name="name" required />
          </div>
          <div class="form-group">
            <label for="email">EMAIL</label>
            <input type="email" id="email" name="email" required />
          </div>
          <div class="form-group">
            <label for="company">COMPANY</label>
            <input type="text" id="company" name="company" />
          </div>
          <div class="form-group">
            <label for="service">INTERESTED IN</label>
            <select id="service" name="service">
              <option value="">Select a service</option>
              <option value="audit">Brand Audit / 品牌世代健檢</option>
              <option value="translation">MZ Translation / 品牌語言轉譯</option>
              <option value="channel">Channel Strategy / 溝通管道重構</option>
              <option value="coaching">Executive Coaching / 主管世代思維訓練</option>
              <option value="other">Other / 其他</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">MESSAGE</label>
            <textarea id="message" name="message" rows="5" placeholder="簡單描述你的品牌現況與挑戰..."></textarea>
          </div>
          <button type="submit" class="btn-submit">SEND MESSAGE</button>
        </form>
      </div>
    </div>
  </section>

</Base>

<style>
  .page-hero {
    padding: calc(var(--nav-h) + 6rem) 2rem 4rem;
    border-bottom: 1px solid var(--gray-800);
  }
  .page-hero-inner { max-width: var(--max-w); margin: 0 auto; }
  .page-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    background: var(--grad-fire);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 2rem;
  }
  .page-title {
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    margin-bottom: 1rem;
    background: var(--grad-main);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .page-sub { font-size: 1.1rem; color: var(--gray-400); }

  .contact-section { padding: 6rem 2rem; }
  .contact-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 6rem;
  }

  .info-block { margin-bottom: 2.5rem; }
  .info-block h3 {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    margin-bottom: 1rem;
  }
  .info-block h4 {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--gray-500);
    margin-bottom: 0.5rem;
  }
  .info-block p {
    color: var(--gray-400);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 0.5rem;
  }
  .info-link {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    background: var(--grad-main);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    border-bottom: 1px solid var(--neon-purple);
    padding-bottom: 2px;
    transition: all 0.2s;
  }
  .info-link:hover { border-color: var(--hot-pink); }
  .info-detail {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--gray-400);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .form-group label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--gray-500);
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    background: var(--dark);
    border: 1px solid var(--gray-800);
    color: var(--white);
    font-family: var(--font-sans);
    font-size: 1rem;
    padding: 0.9rem 1rem;
    outline: none;
    transition: border-color 0.2s;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--neon-purple);
    box-shadow: 0 0 20px rgba(168,85,247,0.15);
  }
  .form-group select {
    appearance: none;
    cursor: pointer;
  }
  .form-group textarea { resize: vertical; min-height: 120px; }

  .btn-submit {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    background: var(--grad-main);
    color: var(--black);
    border: none;
    padding: 1rem 2.5rem;
    cursor: pointer;
    border-radius: 8px;
    transition: all 0.3s;
    align-self: flex-start;
    box-shadow: 0 4px 20px rgba(168,85,247,0.3);
  }
  .btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(168,85,247,0.5);
  }

  @media (max-width: 768px) {
    .contact-inner { grid-template-columns: 1fr; gap: 3rem; }
  }
</style>
